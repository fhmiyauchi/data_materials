# Set your Materials Project API Key here
MP_API_KEY=your_api_key_here

# Apache Superset
SUPERSET_SECRET_KEY=your_superset_secret_key_here
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=your_admin_password_here
SUPERSET_ADMIN_EMAIL=admin@superset.local

# LLM - OpenAI Platform
OPENAI_API_KEY="your_openai_api_key_here"

# AI Configuration Parameters
OPENAI_MODEL_NAME="gpt-5.4-mini"
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
CHROMA_COLLECTION_NAME="materials_semantic"
